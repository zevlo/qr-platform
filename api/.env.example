# AWS credentials - OPTIONAL.
# The app uses boto3 default credential chain, so you only need these if you want
# to override the default (~/.aws/credentials, IRSA, EC2 instance role, etc.):
# AWS_ACCESS_KEY=Your-AWS-Access-Key
# AWS_SECRET_KEY=Your-AWS-Secret-Access-Key

# Required: S3 bucket where QR codes will be stored
BUCKET_NAME=your-qr-codes-bucket-name